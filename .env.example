APP_NAME="Etat Civil Cotonou"
APP_ENV=development
APP_URL=http://localhost:8000

# Base de données locale
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=etat_civil_cotonou
DB_USERNAME=root
DB_PASSWORD=

# Variables injectées automatiquement par Clever Cloud (ne pas renseigner manuellement)
