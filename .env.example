APP_NAME="Etat Civil Cotonou"
APP_ENV=development
APP_URL=http://localhost:8000

# Base de données locale (développement)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=etat_civil_cotonou
DB_USERNAME=root
DB_PASSWORD=

# Variables cloud — injectées automatiquement selon la plateforme
# Render / Railway :
# MYSQLHOST=
# MYSQLPORT=
# MYSQLDATABASE=
# MYSQLUSER=
# MYSQLPASSWORD=

# Clever Cloud :
# MYSQL_ADDON_HOST=
# MYSQL_ADDON_PORT=
# MYSQL_ADDON_DB=
# MYSQL_ADDON_USER=
# MYSQL_ADDON_PASSWORD=

SESSION_LIFETIME=7200
SESSION_SECURE=false

PDF_STORAGE_PATH=storage/pdf/
LOG_PATH=storage/logs/app.log
LOG_LEVEL=debug

MAIRIE_NOM="Mairie de Cotonou"
MAIRIE_LOGO=public/assets/images/logo-mairie.png
